{
  "name": "Sign Up",
  "testCount": 1,
  "tests": [
    {
      "name": "User can sign up with valid credentials",
      "steps": [
        { "action": "visit", "url": "http://localhost:3000/signup" },
        { "action": "type", "selector": "input[name='firstname']", "value": "Test" },
        { "action": "type", "selector": "input[name='lastname']", "value": "User" },
        { "action": "type", "selector": "input[name='email']", "value": "testuser@example.com" },
        { "action": "type", "selector": "input[name='password']", "value": "password123" },
        { "action": "click", "selector": "button[type='submit']" },
        { "action": "url", "should": "include", "value": "/dashboard" }
      ]
    }
  ]
}
